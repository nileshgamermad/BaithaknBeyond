# Server
PORT=5000

# MongoDB Atlas
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/baithak-beyond

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars

# CORS
CLIENT_URL=http://localhost:5173

# Google OAuth
# Get from: console.cloud.google.com → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Facebook OAuth
# Get from: developers.facebook.com → Your App → Settings → Basic
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# Resend (OTP email)
# Get from: resend.com → API Keys
RESEND_API_KEY=re_your_api_key_here
# Must be a verified sender domain in your Resend account
RESEND_FROM_EMAIL=noreply@baithaknbeyond.com

# Apple Sign In
# Get from: developer.apple.com → Certificates, IDs & Profiles
APPLE_CLIENT_ID=com.yourcompany.baithak-beyond   # your Services ID
APPLE_TEAM_ID=YOUR_TEAM_ID
APPLE_KEY_ID=YOUR_KEY_ID
# Paste your private key content (from .p8 file) — keep newlines as \n
APPLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIGT...\n-----END PRIVATE KEY-----
