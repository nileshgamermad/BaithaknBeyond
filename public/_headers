/*
  Cross-Origin-Opener-Policy: unsafe-none
  Cross-Origin-Embedder-Policy: unsafe-none
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin

# Vite hashed assets (JS/CSS chunks) — cache forever, they're content-addressed
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Images and fonts in public/ — cache for 1 week
/*.png
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400
/*.ico
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400
/*.webp
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

# HTML pages — always revalidate so deploys propagate instantly
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Manifest and sitemap — short cache
/manifest.json
  Cache-Control: public, max-age=3600
/sitemap.xml
  Cache-Control: public, max-age=3600
