# Frontend env vars (Vite — must be prefixed with VITE_)
# Copy this file to .env.local and fill in your values

VITE_API_URL=http://localhost:5000/api

# Google OAuth (same Client ID as the backend)
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Facebook (App ID only — secret stays server-side)
VITE_FACEBOOK_APP_ID=your_facebook_app_id

# Apple Sign In (Services ID — same as APPLE_CLIENT_ID in server)
VITE_APPLE_CLIENT_ID=com.yourcompany.baithak-beyond
VITE_APPLE_REDIRECT_URI=http://localhost:5173/auth/apple/callback
